@page "/"

<PageTitle>Tessera - Yoga Studio Platform</PageTitle>

<div class="container mt-4">
    <div class="jumbotron p-4 bg-light rounded">
        <h1 class="display-4">Welcome to Tessera 🧘</h1>
        <p class="lead">
            A multi-tenant platform for Yoga professionals to manage their studios, 
            schedule classes, and accept payments from participants.
        </p>
        <hr class="my-4" />
        <p>Use the navigation to manage your studios, bookings, and payments.</p>
        <a class="btn btn-primary btn-lg" href="studios" role="button">Manage Studios</a>
        <a class="btn btn-outline-secondary btn-lg ms-2" href="bookings" role="button">View Bookings</a>
    </div>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">🏫 Studio Management</h5>
                    <p class="card-text">Create and manage multiple yoga studio locations per tenant.</p>
                    <a href="studios" class="btn btn-primary">Go to Studios</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">📅 Class Bookings</h5>
                    <p class="card-text">Allow participants to book yoga class sessions easily.</p>
                    <a href="bookings" class="btn btn-primary">Go to Bookings</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">💳 Payments</h5>
                    <p class="card-text">Process and track payments from class participants.</p>
                    <a href="payments" class="btn btn-primary">Go to Payments</a>
                </div>
            </div>
        </div>
    </div>
</div>
